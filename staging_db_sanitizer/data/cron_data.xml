<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Scheduled Action that runs on Odoo startup -->
        <record id="ir_cron_staging_sanitizer" model="ir.cron">
            <field name="name">Staging Database Sanitizer</field>
            <field name="model_id" ref="model_staging_database_sanitizer"/>
            <field name="state">code</field>
            <field name="code">model.run_sanitization_check()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">minutes</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>


