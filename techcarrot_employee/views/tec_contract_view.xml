<?xml version="1.0" encoding="utf-8" ?>
<odoo>

    <record id="techcarrot_employee_contract_inherit" model="ir.ui.view">
        <field name="name">hr.contract.form</field>
        <field name="model">hr.contract</field>
        <field name="inherit_id" ref="l10n_ae_hr_payroll.hr_contract_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='l10n_ae_other_allowances']" position="after">
                <field name="aat_allowance"/>
                <field name="sub_total"/>
            </xpath>
        </field>
    </record>


</odoo>
