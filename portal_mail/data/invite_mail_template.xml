<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <!-- Email template for new internal users -->
        <record id="portal_send_invite_email" model="mail.template">
            <field name="name">Settings: New Portal User Invite Custom</field>
            <field name="model_id" ref="base.model_res_users"/>
            <field name="subject">Advanced notification for creation of portal account for accessing Employee Self Service Portal</field>
            <field name="email_from">{{ (object.company_id.email_formatted or user.email_formatted) }}</field>
            <field name="partner_to" eval="False"/>
            <field name="use_default_to" eval="True"/>
            <field name="description">Sent to new user after you invited them</field>
            <field name="body_html" type="html">
    <t>
        <table border="0" cellpadding="0" cellspacing="0" style="padding-top:16px; background-color:#FFFFFF; font-family:Verdana, Arial, sans-serif; color:#454748; width:100%; border-collapse:separate;">
            <tr>
                <td align="center">
                    <table border="0" cellpadding="0" cellspacing="0" width="590" style="padding:16px; background-color:#FFFFFF; color:#454748; border-collapse:separate;">
                        <tbody>

                            <!-- HEADER -->
                            <tr>
                                <td align="center" style="min-width:590px;">
                                    <table border="0" cellpadding="0" cellspacing="0" width="590" style="min-width:590px; background-color:white; padding:0px 8px;">
                                        <tr>
                                            <td valign="middle">
                                                <span style="font-size:10px;">Employee Self Service Portal</span><br/>
                                                <span style="font-size:20px; font-weight:bold;">
                                                    <t t-out="object.name or ''"/>
                                                </span>
                                            </td>
                                            <td valign="middle" align="right" t-if="not object.company_id.uses_default_logo">
                                                <img t-attf-src="/logo.png?company={{ object.company_id.id }}" style="width:80px;" t-att-alt="object.company_id.name"/>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td colspan="2" style="text-align:center;">
                                                <hr style="background-color:#CCCCCC; border:none; height:1px; margin:16px 0;"/>
                                            </td>
                                        </tr>
                                    </table>
                                </td>
                            </tr>

                            <!-- CONTENT -->
                            <tr>
                                <td align="center">
                                    <table border="0" cellpadding="0" cellspacing="0" width="590" style="background-color:white; padding:0px 8px;">
                                        <tr>
                                            <td style="font-size:13px;">
                                                <div>
                                                    Dear <t t-out="object.name or ''"/>,<br/><br/>

                                                    Welcome to <t t-out="object.company_id.name or ''"/>'s Employee Self Service Portal!<br/><br/>

                                                    This is an advance notification to inform you that your account has been created on the newly launched HRIS platform.<br/><br/>

                                                    Your Login ID:
                                                    <b><t t-out="object.email or ''"/></b><br/><br/>

                                                    Please stay tuned for a follow-up email from the HR Department, which will include detailed instructions on how to access and use your account. The follow-up email will be sent around Friday.<br/><br/>

                                                    Regards,<br/>
                                                    HR Team
                                                </div>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td style="text-align:center;">
                                                <hr style="background-color:#CCCCCC; border:none; height:1px; margin:16px 0;"/>
                                            </td>
                                        </tr>
                                    </table>
                                </td>
                            </tr>

                            <!-- FOOTER -->
                            <tr>
                                <td align="center">
                                    <table border="0" cellpadding="0" cellspacing="0" width="590" style="background-color:white; font-size:11px; padding:0px 8px;">
                                        <tr>
                                            <td>
                                                <t t-out="object.company_id.name or ''"/>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td style="opacity:0.7;">
                                                <t t-out="object.company_id.phone or ''"/>
                                                <t t-if="object.company_id.email">
                                                    | <a t-att-href="'mailto:%s' % object.company_id.email" style="color:#454748;">
                                                        <t t-out="object.company_id.email"/>
                                                    </a>
                                                </t>
                                                <t t-if="object.company_id.website">
                                                    | <a t-att-href="object.company_id.website" style="color:#454748;">
                                                        <t t-out="object.company_id.website"/>
                                                    </a>
                                                </t>
                                            </td>
                                        </tr>
                                    </table>
                                </td>
                            </tr>

                        </tbody>
                    </table>
                </td>
            </tr>


        </table>
    </t>
</field>



        </record>

    </data>
</odoo>