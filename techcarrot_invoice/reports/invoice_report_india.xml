<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <template id="report_techcarrot_invoices_india_document">
            <t t-call="web.html_container">
                <t t-call="techcarrot_invoice.tech_india_invoice_layout">
                    <style>
                        table, th, td {
                            border:1px solid black;
                            padding-left:10px;
                            padding:5px;
                        }
                        .br-right {
                            border:1px solid black;
                            padding:5px;
                        }
                        .text-right {
                            text-align: end;
                        }
                    </style>
                    <div class="page" >
                        <div class="row mb-4">
                            <div class="col-3" name="logo">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <img t-if="o.company_id.logo" class="o_company_logo_small" t-att-src="image_data_uri(o.company_id.logo)" alt="Logo"/>
                                </div>
                            </div>
                            <div class="col-5" name="div_billing_address" >
<!--                                <div name="partner_header" class="row mb-4">-->
                                <div class="no-border" style="font-size:24px;"><b><t t-esc="o.company_id.name"/></b></div>
                                <div class="no-border" ><t t-esc="o.company_id.street"/>, <t t-esc="o.company_id.street2"/></div>
                                <div class="no-border" ><t t-esc="o.company_id.city"/></div>
                                <div class="no-border" ><t t-esc="o.company_id.zip"/></div>
                                <div class="no-border" ><t t-esc="o.company_id.state_id.name"/>, <t t-esc="o.company_id.country_id.name"/></div>
                                <div class="no-border" >TRN <t t-esc="o.company_id.vat"/></div>
                            </div>
                            <div class="col-4" name="logo">
                                <div style="display: flex; flex-direction: column; justify-content: flex-end; height: 200px; text-align: right ; margin-right: 10px;">
                                    <h3>TAX INVOICE</h3>
                                </div>
                            </div>
                        </div>
                        <div class="row mb-4" style="border: 1px solid #ccc;">
                            <div class="col-6" name="bill_to_address" style="border: 1px solid #ccc;">
                                <table width="100%" class="table table-borderless" style="border : none;">
                                    <tr>
                                        <td width="45%"><span>Invoice #</span></td>
                                        <td width="3%">:</td>
                                        <td width="52%"><span t-field="o.name"></span> </td>
                                    </tr>
                                    <tr>
                                        <td ><span>Invoice Date</span></td>
                                        <td >:</td>
                                        <td ><span t-field="o.invoice_date"></span> </td>
                                    </tr>
                                    <tr>
                                        <td ><span>Terms</span></td>
                                        <td >:</td>
                                        <td ><span t-field="o.name"></span> </td>
                                    </tr>
                                    <tr>
                                        <td ><span>Due Date</span></td>
                                        <td >:</td>
                                        <td ><span t-field="o.name"></span> </td>
                                    </tr>
                                    <tr>
                                        <td ><span>P.O.#</span></td>
                                        <td >:</td>
                                        <td>
                                            <t t-if="o.line_ids.sale_line_ids">
                                                <span t-field="o.line_ids.sale_line_ids.order_id.client_order_ref"></span>
                                            </t>
                                        </td>
                                    </tr>
                                </table>
                            </div>
                            <div class="col-6" name="ship_to_address" style="border: 1px solid #ccc;">
                                <table width="100%" class="table table-borderless" style="border : none;">
                                    <td width="45%">Invoice amount in INR</td>
                                    <td width="3%">:</td>
                                    <td width="52%"><span t-field="o.amount_total"/> </td>
                                </table>
                            </div>
                        </div>
                        <div class="row mb-4" style="border: 1px solid #ccc;">
                            <div class="col-6" name="bill_to_address">
                                <div name="bill_to_address" style="border: 1px solid #ccc;">
                                    <strong>Bill To</strong>
                                </div>
                                <div name="partner_header">
                                    <div class="no-border" style="font-size:24px;"><b><t t-esc="o.partner_id.name"/></b></div>
                                    <div class="no-border" ><t t-esc="o.partner_id.street"/>, <t t-esc="o.partner_id.street2"/></div>
                                    <div class="no-border" ><t t-esc="o.partner_id.city"/></div>
                                    <div class="no-border" ><t t-esc="o.partner_id.zip"/></div>
                                    <div class="no-border" ><t t-esc="o.partner_id.state_id.name"/>, <t t-esc="o.partner_id.country_id.name"/></div>
                                    <div class="no-border" >TRN <t t-esc="o.partner_id.vat"/></div>
                                </div>
                            </div>
                            <div class="col-6" name="ship_to_address">
                                <div name="customer_address" style="border: 1px solid #ccc;">
                                    <strong>Ship To</strong>
                                </div>
                                <div name="partner_header" style="border: 1px solid #ccc;">
                                    <div class="no-border" style="font-size:24px;"><b><t t-esc="o.partner_id.name"/></b></div>
                                    <div class="no-border" ><t t-esc="o.partner_id.street"/>, <t t-esc="o.partner_id.street2"/></div>
                                    <div class="no-border" ><t t-esc="o.partner_id.city"/></div>
                                    <div class="no-border" ><t t-esc="o.partner_id.zip"/></div>
                                    <div class="no-border" ><t t-esc="o.partner_id.state_id.name"/>, <t t-esc="o.partner_id.country_id.name"/></div>
                                    <div class="no-border" >TRN <t t-esc="o.partner_id.vat"/></div>
                                </div>
                            </div>
                        </div>

                        <div class="clearfix invoice_main">
                        <div class="page mb-4">
                            <table width="100%"  style="border:none;" name="invoice_line_table">
                                <thead>
                                    <tr style="background-color:#d6d6d6;">
                                        <th rowspan="2" name="th_description" width="5%" class="text-center"><span>#</span></th>
                                        <th rowspan="2" name="th_description" width="28%" class="text-start"><span>Item &amp; Description</span></th>
                                        <th rowspan="2" name="th_quantity" width="10%"  class="text-start"><span>HSN/SAC</span></th>
                                        <th rowspan="2" name="th_quantity" width="11%"  class="text-end"><span>Qty</span></th>
                                        <th rowspan="2" name="th_quantity" width="13%" class="text-end"><span>Rate</span></th>
                                        <th colspan="2" name="th_quantity" width="18%" class="text-center"><span>IGST</span></th>
                                        <th rowspan="2" name="th_quantity" width="15%" class="text-end"><span>Amount</span></th>
                                    </tr>
                                    <tr style="background-color:#d6d6d6;">
                                        <th class="text-end" >%</th>
                                        <th class="text-end" >Amt</th>
                                  </tr>
                                </thead>
                                <tbody class="invoice_tbody">
                                    <t t-set="lines" t-value="o.invoice_line_ids.sorted(key=lambda l: (-l.sequence, l.date, l.move_name, -l.id), reverse=True)"/>
                                    <t t-set="count" t-value="0"/>
                                    <t t-foreach="lines" t-as="line">
                                        <t t-set="count" t-value="count + 1"/>
                                        <tr style="border-bottom:none;border-top:none" t-att-class="'fw-bold o_line_section' if line.display_type == 'line_section' else 'fst-italic o_line_note' if line.display_type == 'line_note' else ''">
                                            <t t-if="line.display_type == 'product'" name="account_invoice_line_accountable">
                                                <td class="text-center text-nowrap" style="border:none">
                                                    <span t-out="count"></span>
                                                </td>
                                                <td name="account_invoice_line_name" style="border-bottom:none;border-top:none">
                                                    <span t-if="line.name" t-field="line.name" t-options="{'widget': 'text'}">Bacon Burger</span>
<!--                                                    <span t-if="line.name" t-field="line.name" t-options="{'widget': 'text'}">Bacon Burger</span>-->
                                                </td>
                                                <td class="text-center text-nowrap" style="border:none">
                                                    <span t-if="line.product_id.l10n_in_hsn_code" t-field="line.product_id.l10n_in_hsn_code" t-options="{'widget': 'text'}">Bacon Burger</span>
                                                </td>
                                                <td name="td_quantity" class="text-end text-nowrap" style="border-bottom:none;border-top:none">
                                                    <span t-out="line._check_qty_whole_fraction()">3.00</span>
                                                    <span t-field="line.product_uom_id"  groups="uom.group_uom">units</span>
                                                </td>
                                                <td name="td_price_unit" style="border-bottom:none;border-top:none" t-attf-class="text-end {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}">
                                                    <span class="text-nowrap" t-field="line.price_unit">9.00</span>
                                                </td>
                                                <t t-set="taxes" t-value="', '.join([(tax.invoice_label or tax.name) for tax in line.tax_ids])"/>
                                                <td name="td_taxes" style="border-bottom:none;border-top:none" t-attf-class="text-end {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }} {{ 'text-nowrap' if len(taxes) &lt; 10 else '' }}">
<!--                                                    <t t-set="l10n_ae_vat_amount" t-value="'{:,.2f}'.format(line.l10n_ae_vat_amount)"/>-->
<!--                                                    <span t-esc="l10n_ae_vat_amount" id="line_tax_ids">Tax 15%</span><br></br>-->
                                                    <span t-out="taxes" id="line_tax_ids"></span>
                                                </td>
                                                <td name="td_taxes" style="border-bottom:none;border-top:none" t-attf-class="text-end {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }} {{ 'text-nowrap' if len(taxes) &lt; 10 else '' }}">
                                                    <t t-set="l10n_ae_vat_amount" t-value="'{:,.2f}'.format(line.l10n_ae_vat_amount)"/>
                                                    <span t-esc="l10n_ae_vat_amount" id="line_tax_ids">Tax 15%</span>
<!--                                                    <span t-out="taxes" id="line_tax_ids"></span>-->
                                                </td>
                                                <td name="td_subtotal" style="border-bottom:none;border-top:none" class="text-end o_price_total">
                                                    <t t-set="subtotal" t-value="'{:,.2f}'.format(line.price_subtotal)"/>
                                                    <span class="text-nowrap" t-esc="subtotal">27.00</span>
                                                </td>
                                            </t>
                                            <t t-elif="line.display_type == 'line_section'">
                                                <td style="border-bottom:none;border-top:none" >
                                                    <span t-field="line.name" t-options="{'widget': 'text'}">A section title</span>
                                                </td>
                                                <td style="color: #ffffff;border-bottom:none;border-top:none" >UOM</td>
                                                <td style="color: #ffffff;border-bottom:none;border-top:none" >UOM</td>
                                                <td style="color: #ffffff;border-bottom:none;border-top:none" >UOM</td>
                                                <td style="color: #ffffff;border-bottom:none;border-top:none" >UOM</td>
                                                <td style="color: #ffffff;border-bottom:none;border-top:none" >UOM</td>
                                                <td style="color: #ffffff;border-bottom:none;border-top:none" >UOM</td>
                                                <td style="color: #ffffff;border-bottom:none;border-top:none" >UOM</td>
                                            </t>
                                            <t t-elif="line.display_type == 'line_note'">
                                                <td style="border-bottom:none;border-top:none" >
                                                    <span t-field="line.name" t-options="{'widget': 'text'}">A note, whose content usually applies to the section or product above.</span>
                                                </td>
                                                <td style="color: #ffffff;border-bottom:none;border-top:none" >UOM</td>
                                                <td style="color: #ffffff;border-bottom:none;border-top:none" >UOM</td>
                                                <td style="color: #ffffff;border-bottom:none;border-top:none" >UOM</td>
                                                <td style="color: #ffffff;border-bottom:none;border-top:none" >UOM</td>
                                                <td style="color: #ffffff;border-bottom:none;border-top:none" >UOM</td>
                                                <td style="color: #ffffff;border-bottom:none;border-top:none" >UOM</td>
                                                <td style="color: #ffffff;border-bottom:none;border-top:none" >UOM</td>
                                            </t>
                                        </tr>
                                    </t>
                                    <t t-set="lines" t-value="o.invoice_line_ids"/>
                                    <t t-foreach="range(max(3-len(lines),0))" t-as="ln">
                                        <tr style="color: #ffffff;border-bottom:none;border-top:none" >
                                            <td style="color: #ffffff;border-bottom:none;border-top:none" >Packs</td>
                                            <td style="color: #ffffff;border-bottom:none;border-top:none" >UOM</td>
                                            <td style="color: #ffffff;border-bottom:none;border-top:none" >Particulars</td>
                                            <td style="color: #ffffff;border-bottom:none;border-top:none" >SKU</td>
                                            <td style="color: #ffffff;border-bottom:none;border-top:none" >SKU</td>
                                            <td style="color: #ffffff;border-bottom:none;border-top:none" >SKU</td>
                                            <td style="color: #ffffff;border-bottom:none;border-top:none" >SKU</td>
                                            <td style="color: #ffffff;border-bottom:none;border-top:none" >SKU</td>
                                        </tr>
                                    </t>
                                    <tr style="border-top:none;">
                                        <td style="border-top:none;"></td>
                                        <td style="border-top:none;"></td>
                                        <td style="border-top:none;" ></td>
                                        <td style="border-top:none;"></td>
                                        <td style="border-top:none;"></td>
                                        <td style="border-top:none;"></td>
                                        <td style="border-top:none;"></td>
                                        <td style="border-top:none;"></td>
                                    </tr>
                                </tbody>
                            </table>
                            <br/>
                            <br/>
                            <div class="row mb-4">
                                <div class="col-6" name="logo">
                                    <div class="text-muted">Total In Words:</div><br/>
                                    <p >
                                        <b><span t-field="o.currency_id.name"></span> <span t-field="o.amount_total_words"></span></b>
                                    </p>
                                </div>
                                <div class="col-6" name="logo">
                                    <table class="o_total_table table  table-borderless avoid-page-break-inside" style="border : none">
                                        <!-- Tax totals summary (invoice currency) -->
                                        <t t-if="o.tax_totals" >
                                            <t t-set="tax_totals" t-value="o.tax_totals"/>
                                            <t t-set="currency" t-value="o.currency_id.name"/>
                                            <tr class="o_total" >
                                                <td class="text-end">Sub Total</td>
                                                <td class="text-end o_price_total">
                                                    <t t-set="amount_untaxed" t-value="'{:,.2f}'.format(o.amount_untaxed)"/>
                                                    <span class="text-nowrap" t-esc="amount_untaxed" >31.05</span>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td class="text-end">IGST0 (0%)</td>
                                                <td class="text-end o_price_total">
                                                    <t t-set="amount_tax" t-value="'{:,.2f}'.format(o.amount_tax)"/>
                                                    <span class="text-nowrap" t-esc="amount_tax" >31.05</span>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td class="text-end"><b>Total</b></td>
                                                <td class="text-end o_price_total">
                                                    <t t-set="amount_total" t-value="'{:,.2f}'.format(o.amount_total)"/>
                                                    <span class="text-nowrap" t-esc="amount_total" >31.05</span>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td class="text-end"><b>Balance Due</b></td>
                                                <td class="text-end o_price_total">
                                                    <t t-set="amount_residual" t-value="'{:,.2f}'.format(o.amount_residual)"/>
                                                    <span class="text-nowrap" t-esc="amount_residual" >31.05</span>
                                                </td>
                                            </tr>
                                        </t>
                                    </table>
                                </div>
                            </div>
                        </div>
                        </div>
                        <div class="page mb-4">
                            <div style="text-decoration: underline;font-size:20px;"><b>Bank Details For Transfers</b></div>
                            <br></br>
                            <span style="padding-left: 20px"><b>Company name : <span t-field="o.company_id.bank_ids[0].partner_id.name"/></b></span><br/>
                            <span style="padding-left: 20px"><b>Account number : <span t-field="o.company_id.bank_ids[0].acc_number"/></b></span><br/>
                            <span style="padding-left: 20px"><b>IFSC : <span t-field="o.company_id.bank_ids[0].bank_id.bic"/></b></span><br/>
                            <span style="padding-left: 20px"><b>SWIFT Code : <span t-field="o.company_id.bank_ids[0].bank_id.bic"/></b></span><br/>
                            <span style="padding-left: 20px"><b>Bank name : <span t-field="o.company_id.bank_ids[0].bank_id.name"/></b></span><br/>
                            <span style="padding-left: 20px"><b>Branch : <span t-field="o.company_id.bank_ids[0].bank_id.name"/></b></span><br/>

                        </div>
                    </div>

                </t>
            </t>
        </template>

        <template id="report_techcarrot_invoices_india">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="o">
                    <t t-call="techcarrot_invoice.report_techcarrot_invoices_india_document" t-lang="o.partner_id.lang"/>
                </t>
            </t>
        </template>


        <template id="report_footer_tech_india">
            <div class="footer" style="font-size:10px;">
<!--                <div>-->
                <span>This is a system generated document &amp; does not require a signature.</span>
<!--                            </div>-->
            </div>
        </template>


        <template id="tech_india_invoice_layout">
            <t t-call="web.html_container">
                <t t-if="not o" t-set="o" t-value="doc"/>
                <div class="article" t-att-data-oe-model="o and o._name" t-att-data-oe-id="o and o.id" t-att-data-oe-lang="o and o.env.context.get('lang')" style="border: 1px solid #ccc;">
                    <t t-out="0"/>
                </div>
                <t t-call="techcarrot_invoice.report_footer_tech_india" />
            </t>
        </template>


    </data>
</odoo>
