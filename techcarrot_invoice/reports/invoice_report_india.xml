                    </td>
                </tr>
            </table>

            <!-- Bill To / Ship To -->
            <table class="table" style="font-size: 12px; width: 100%;">
                <tr>
                    <td width="50%">
                        <strong>Bill To</strong><br/>
                        Prime Medical Center LLC<br/>
                        203, Sheikh Saud Al Qasimi Bldg, 2nd Floor,<br/>
                        Salah Al Deen St, Deira, PO Box 7162, Dubai<br/>
                        United Arab Emirates<br/>
                        <strong>TRN:</strong> 100297778100003
                    </td>
                    <td width="50%">
                        <strong>Ship To</strong><br/>
                        203, Sheikh Saud Al Qasimi Bldg, 2nd Floor,<br/>
                        Salah Al Deen St, Deira, PO Box 7162, Dubai<br/>
                        United Arab Emirates<br/>
                        <strong>TRN:</strong> 100297778100003
                    </td>
                </tr>
            </table>

            <!-- Invoice Line Items -->
            <table class="table table-sm" style="width:100%; font-size: 12px;" border="1">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Item &amp; Description</th>
                        <th>HSN/SAC</th>
                        <th>Qty</th>
                        <th>Rate</th>
                        <th>IGST %</th>
                        <th>Amt</th>
                        <th>Amount</th>
                    </tr>
                </thead>
                <tbody>
                    <t t-foreach="o.invoice_line_ids" t-as="line" t-set="idx" t-value="0">
                        <tr>
                            <td><t t-esc="line.sequence or loop.index"/></td>
