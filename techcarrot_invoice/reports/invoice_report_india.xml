                        <div class="row" style="border: 1px solid #ccc;margin: 0; padding: 0;">
                            <div class="col-6" name="bill_to_address" >
                                <table width="100%" class="table table-borderless" style="border : none;">
                                    <tr >
                                        <td width="45%"><span>Invoice #</span></td>
                                        <td width="3%">:</td>
                                        <td width="52%"><b><span t-field="o.name"></span></b> </td>
                                    </tr>
                                    <tr>
                                        <td ><span>Invoice Date</span></td>
                                        <td >:</td>
                                        <td ><b><span t-field="o.invoice_date"></span></b> </td>
                                    </tr>
                                    <tr>
                                        <td ><span>Terms</span></td>
                                        <td >:</td>
                                        <td ><b><span t-field="o.invoice_payment_term_id.name"></span> </b></td>
                                    </tr>
                                    <tr>
                                        <td ><span>Due Date</span></td>
                                        <td >:</td>
                                        <td ><b><span t-field="o.invoice_date_due"></span> </b></td>
                                    </tr>
                                    <tr>
                                        <td ><span>P.O.#</span></td>
                                        <td >:</td>
                                        <td>
                                            <t t-if="o.line_ids.sale_line_ids">
                                                <b><span t-field="o.line_ids.sale_line_ids.order_id.client_order_ref"></span></b>
                                            </t>
                                        </td>
                                    </tr>
                                </table>
                            </div>
                            <div class="col-6" name="ship_to_address" style="border-left: 1px solid #ccc;">
                                <table width="100%" class="table table-borderless" style="border : none;">
                                    <td width="45%">Invoice amount in INR</td>
                                    <td width="3%">:</td>
                                    <td width="52%">
                                        <t t-set="amount_total" t-value="'{:,.2f}'.format(o.amount_total)"/>
                                        <b><span t-esc="amount_total"/> </b>
                                    </td>
                                </table>
                            </div>
                        </div>
