<template id="report_invoice_custom">
    <t t-call="web.html_container">
        <t t-call="web.external_layout">
            <!-- Logo + Company Info -->
            <div style="text-align: center; margin-bottom: 10px;">
                <img t-att-src="'data:image/png;base64,%s' % company.logo" style="max-height: 80px;" alt="Company Logo"/>
            </div>
            <h2 style="text-align: center;">techcarrot India Private Limited</h2>
            <p style="text-align: center; font-size: 12px;">
                Floor No.: 5TH &amp; 6TH, Isprout Neelankarai Link Road,<br/>
                Perungudi, Chennai, Tamilnadu 600096, India<br/>
                GSTIN: 33AAHCT6185D1ZB | LUT: AD300245009112S<br/>
                IEC CODE: XXXXXXXX
            </p>
            <h3 style="text-align: right;">TAX INVOICE</h3>

            <!-- Invoice Info -->
            <table class="table" style="font-size: 12px;">
                <tr>
                    <td>
                        <strong>Invoice #</strong>: <span t-field="o.name"/><br/>
                        <strong>Invoice Date</strong>: <span t-field="o.invoice_date"/><br/>
                        <strong>Terms</strong>: Net 7<br/>
                        <strong>Due Date</strong>: <span t-field="o.invoice_date_due"/><br/>
                        <strong>P.O. #</strong>: <t t-esc="o.ref or 'Agreement - SLC-SCA-216A01-00001-2024'"/>
                    </td>
                    <td>
                        <strong>Invoice amount in INR</strong>: <span t-esc="'{:,.2f}'.format(o.amount_total)"/>
                    </td>
                </tr>
            </table>

            <!-- Bill To / Ship To -->
            <table class="table" style="font-size: 12px; width: 100%;">
                <tr>
                    <td width="50%">
                        <strong>Bill To</strong><br/>
                        Prime Medical Center LLC<br/>
                        203, Sheikh Saud Al Qasimi Bldg, 2nd Floor,<br/>
                        Salah Al Deen St, Deira, PO Box 7162, Dubai<br/>
                        United Arab Emirates<br/>
                        <strong>TRN:</strong> 100297778100003
                    </td>
                    <td width="50%">
                        <strong>Ship To</strong><br/>
                        203, Sheikh Saud Al Qasimi Bldg, 2nd Floor,<br/>
                        Salah Al Deen St, Deira, PO Box 7162, Dubai<br/>
                        United Arab Emirates<br/>
                        <strong>TRN:</strong> 100297778100003
                    </td>
                </tr>
            </table>

            <!-- Invoice Line Items -->
            <table class="table table-sm" style="width:100%; font-size: 12px;" border="1">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Item &amp; Description</th>
                        <th>HSN/SAC</th>
                        <th>Qty</th>
                        <th>Rate</th>
                        <th>IGST %</th>
                        <th>Amt</th>
                        <th>Amount</th>
                    </tr>
                </thead>
                <tbody>
                    <t t-foreach="o.invoice_line_ids" t-as="line" t-set="idx" t-value="0">
                        <tr>
                            <td><t t-esc="line.sequence or loop.index"/></td>
                            <td><t t-esc="line.name"/></td>
                            <td><t t-esc="line.product_id.hs_code or '998314'"/></td>
                            <td><t t-esc="line.quantity"/></td>
                            <td><t t-esc="'{:,.2f}'.format(line.price_unit)"/></td>
                            <td>0%</td>
                            <td>0.00</td>
                            <td><t t-esc="'{:,.2f}'.format(line.price_subtotal)"/></td>
                        </tr>
                    </t>
                </tbody>
            </table>

            <!-- Totals Section -->
            <table class="table" style="font-size: 12px; width: 100%;">
                <tr>
                    <td width="70%">
                        <strong>Total In Words</strong><br/>
                        <span t-esc="o.currency_id.amount_to_text(o.amount_total)"/>
                    </td>
                    <td width="30%">
                        <table class="table table-sm">
                            <tr><td>Sub Total</td><td><t t-esc="'{:,.2f}'.format(o.amount_untaxed)"/></td></tr>
                            <tr><td>IGST 0%</td><td>0.00</td></tr>
                            <tr><td><strong>Total</strong></td><td><strong><t t-esc="'{:,.2f}'.format(o.amount_total)"/></strong></td></tr>
                            <tr><td><strong>Balance Due</strong></td><td><strong><t t-esc="'{:,.2f}'.format(o.amount_total)"/></strong></td></tr>
                        </table>
                    </td>
                </tr>
            </table>

            <!-- Notes -->
            <p><strong>Notes</strong><br/>
                <span t-field="o.narration" style="white-space: pre-line;"/>
            </p>

            <!-- Bank Details -->
            <p>
                <strong>Bank Details For Transfers</strong><br/>
                <strong>Company name:</strong> TECHCARROT INDIA PRIVATE LIMITED<br/>
                <strong>Account number:</strong> 10051201283<br/>
                <strong>IFSC:</strong> IDFB0020123<br/>
                <strong>SWIFT code:</strong> IDFBINBBMUM
            </p>
        </t>
    </t>
</template>
