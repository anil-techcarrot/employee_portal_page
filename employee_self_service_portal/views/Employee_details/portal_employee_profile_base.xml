<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="portal_employee_profile_base">
        <t t-call="portal.portal_layout">
            <div class="o_portal container my-4">

                <!-- Header Section -->
                <div class="card mb-4 shadow-sm">
                    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                        <div>
                            <h4 class="mb-1">Employee Profile</h4>
                            <small class="opacity-75">Manage your personal information and settings</small>
                        </div>
                        <div class="d-flex gap-2">
                            <span class="badge bg-light text-dark">
                                <i class="fa fa-chart-pie me-1"></i>
                                Profile Management
                            </span>
                        </div>
                    </div>
                    <div class="card-body p-4">
                        <div class="row align-items-center">

                            <!-- Left: Employee Info -->
                            <div class="col-md-8">
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <div class="d-flex align-items-center">
                                            <div class="icon-box bg-primary bg-opacity-10 text-primary rounded-circle p-2 me-3">
                                                <i class="fa fa-user"></i>
                                            </div>
                                            <div>
                                                <small class="text-muted d-block">Full Name</small>
                                                <strong><t t-esc="employee.name"/></strong>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="d-flex align-items-center">
                                            <div class="icon-box bg-success bg-opacity-10 text-success rounded-circle p-2 me-3">
                                                <i class="fa fa-id-badge"></i>
                                            </div>
                                            <div>
                                                <small class="text-muted d-block">Employee ID</small>
                                                <strong><t t-esc="employee.emp_code or 'Not Set'"/></strong>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="d-flex align-items-center">
                                            <div class="icon-box bg-info bg-opacity-10 text-info rounded-circle p-2 me-3">
                                                <i class="fa fa-building"></i>
                                            </div>
                                            <div>
                                                <small class="text-muted d-block">Department</small>
                                                <strong><t t-esc="employee.department_id.name or 'Not Assigned'"/></strong>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="d-flex align-items-center">
                                            <div class="icon-box bg-warning bg-opacity-10 text-warning rounded-circle p-2 me-3">
                                                <i class="fa fa-briefcase"></i>
                                            </div>
                                            <div>
                                                <small class="text-muted d-block">Position</small>
                                                <strong><t t-esc="employee.job_id.name or employee.job_title or 'Not Set'"/></strong>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Right: Photo Upload -->
                            <div class="col-md-4 text-center">
                                <div class="position-relative mb-3" style="display:inline-block;">
                                    <img t-if="employee.image_1920"
                                         t-attf-src="/web/image/hr.employee/{{employee.id}}/image_1920/150x150"
                                         id="employeePhotoImg"
                                         class="rounded-circle shadow"
                                         style="width:120px;height:120px;object-fit:cover;"
                                         alt="Employee Photo"/>
                                    <img t-else=""
                                         src="/web/static/src/img/avatar.png"
                                         id="employeePhotoImg"
                                         class="rounded-circle shadow opacity-50"
                                         style="width:120px;height:120px;object-fit:cover;"
                                         alt="Default Avatar"/>
                                    <label for="photoUploadInput"
                                           style="position:absolute;bottom:4px;right:4px;
                                                  background:#6f42c1;border-radius:50%;
                                                  width:34px;height:34px;
                                                  display:flex;align-items:center;justify-content:center;
                                                  cursor:pointer;
                                                  box-shadow:0 2px 6px rgba(0,0,0,0.35);
                                                  border:2px solid #fff;"
                                           title="Upload Photo">
                                        <i class="fa fa-camera text-white" style="font-size:13px;"></i>
                                    </label>
                                    <input type="file"
                                           id="photoUploadInput"
                                           accept="image/jpeg,image/png,image/gif"
                                           style="display:none;"/>
                                </div>
                                <div id="photoUploadStatus" class="small mt-1" style="min-height:18px;"></div>
                                <div class="text-center">
                                    <h6 class="mb-1"><t t-esc="employee.name"/></h6>
                                    <small class="text-muted">
                                        <i class="fa fa-circle text-success me-1" style="font-size:8px;"></i>
                                        Active Employee
                                    </small>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>

                <!-- Navigation Tabs -->
                <div class="mb-4">
                    <ul class="nav nav-pills nav-fill bg-light p-2 rounded shadow-sm">
                        <li class="nav-item">
                            <a t-attf-class="nav-link rounded {{'active fw-bold' if section == 'personal' else 'text-muted'}}"
                               href="/my/employee/personal">
                                <i class="fa fa-user me-2"></i>
                                <span class="d-none d-md-inline">Personal Details</span>
                                <span class="d-md-none">Personal</span>
                            </a>
                        </li>
<!--                        <li class="nav-item">-->
<!--                            <a t-attf-class="nav-link rounded {{'active fw-bold' if section == 'payroll' else 'text-muted'}}"-->
<!--                               href="/my/employee/payroll">-->
<!--                                <i class="fa fa-money me-2"></i>-->
<!--                                Payroll-->
<!--                            </a>-->
<!--                        </li>-->
                        <li class="nav-item">
                            <a t-attf-class="nav-link rounded {{'active fw-bold' if section == 'experience' else 'text-muted'}}"
                               href="/my/employee/experience">
                                <i class="fa fa-briefcase me-2"></i>
                                <span class="d-none d-md-inline">Experience and Skills</span>
                                <span class="d-md-none">Experience</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a t-attf-class="nav-link rounded {{'active fw-bold' if section == 'certification' else 'text-muted'}}"
                               href="/my/employee/certification">
                                <i class="fa fa-certificate me-2"></i>
                                <span class="d-none d-md-inline">Certifications</span>
                                <span class="d-md-none">Certs</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a t-attf-class="nav-link rounded {{'active fw-bold' if section == 'bank' else 'text-muted'}}"
                               href="/my/employee/bank">
                                <i class="fa fa-university me-2"></i>
                                <span class="d-none d-md-inline">Bank Details</span>
                                <span class="d-md-none">Banking</span>
                            </a>
                        </li>
                        <!-- NEW ORG CHART TAB -->
                        <li class="nav-item">
                            <a t-attf-class="nav-link rounded {{'active fw-bold' if section == 'orgchart' else 'text-muted'}}"
                               href="/my/employee/orgchart">
                                <i class="fa fa-sitemap me-2"></i>
                                <span class="d-none d-md-inline">Org Chart</span>
                                <span class="d-md-none">Org</span>
                            </a>
                        </li>
                    </ul>
                </div>

                <!-- Section Content -->
                <div class="section-content">
                    <t t-raw="section_content"/>
                </div>

                <!-- CSS -->
                <style>
                    .icon-box {
                        width: 40px;
                        height: 40px;
                        display: flex;
                        align-items: center;
                        justify-content: center;
                        font-size: 16px;
                    }
                    .nav-pills .nav-link {
                        transition: all 0.3s ease;
                        border: 1px solid transparent;
                    }
                    .nav-pills .nav-link:hover {
                        background-color: rgba(13, 110, 253, 0.1);
                        border-color: rgba(13, 110, 253, 0.2);
                    }
                    .nav-pills .nav-link.active {
                        background: linear-gradient(135deg, #0d6efd, #0056b3);
                        border-color: #0056b3;
                        box-shadow: 0 2px 4px rgba(13, 110, 253, 0.3);
                    }
                    .card { transition: box-shadow 0.3s ease; }
                    .card:hover { box-shadow: 0 4px 15px rgba(0,0,0,0.1) !important; }
                    /* Org Chart Styles */
                    .org-node {
                        display: flex;
                        align-items: center;
                        gap: 10px;
                        background: #fff;
                        border: 1px solid #dee2e6;
                        border-radius: 10px;
                        padding: 10px 16px;
                        min-width: 180px;
                        box-shadow: 0 2px 6px rgba(0,0,0,0.07);
                    }
                    .org-node.org-self {
                        border-color: #0d6efd;
                        background: #f0f6ff;
                    }
                    .org-node.org-manager {
                        border-color: #6f42c1;
                        background: #f8f4ff;
                    }
                    .org-node.org-child {
                        border-color: #198754;
                        background: #f0fff4;
                    }
                    .org-name {
                        font-weight: 600;
                        font-size: 14px;
                    }
                    .org-role {
                        font-size: 12px;
                        color: #6c757d;
                    }
                    @media (max-width: 768px) {
                        .icon-box { width: 35px; height: 35px; font-size: 14px; }
                        .org-node { min-width: 140px; padding: 8px 10px; }
                    }
                </style>

                <!-- Photo Upload JS -->
                <script type="text/javascript">
                    document.addEventListener('DOMContentLoaded', function () {
                        var input = document.getElementById('photoUploadInput');
                        if (!input) return;
                        input.addEventListener('change', function () {
                            if (!this.files || !this.files[0]) return;
                            var file = this.files[0];
                            var statusEl = document.getElementById('photoUploadStatus');
                            var imgEl = document.getElementById('employeePhotoImg');
                            if (file.size > 5 * 1024 * 1024) {
                                statusEl.innerHTML = '<span class="text-danger">File too large. Max 5MB.</span>';
                                return;
                            }
                            statusEl.innerHTML = '<span class="text-muted">Uploading...</span>';
                            var formData = new FormData();
                            formData.append('photo', file);
                            fetch('/my/employee/upload-photo', {
                                method: 'POST',
                                body: formData
                            })
                            .then(function(res) { return res.json(); })
                            .then(function(data) {
                                if (data.success) {
                                    imgEl.src = data.image_url + '?t=' + Date.now();
                                    imgEl.classList.remove('opacity-50');
                                    statusEl.innerHTML = '<span class="text-success">Photo updated!</span>';
                                    setTimeout(function() { statusEl.innerHTML = ''; }, 3000);
                                } else {
                                    statusEl.innerHTML = '<span class="text-danger">' + (data.error || 'Upload failed') + '</span>';
                                }
                            })
                            .catch(function() {
                                statusEl.innerHTML = '<span class="text-danger">Upload failed. Try again.</span>';
                            });
                        });
                    });
                </script>

            </div>
        </t>
    </template>

    <!-- ── Org Chart Section Template ── -->
    <template id="portal_employee_profile_orgchart">
        <t t-call="employee_self_service_portal.portal_employee_profile_base">
            <t t-set="section" t-value="'orgchart'"/>
            <t t-set="section_content">
                <div class="card mb-4 shadow-sm">
                    <div class="card-header bg-light">
                        <h5 class="mb-0">
                            <i class="fa fa-sitemap text-primary me-2"></i>
                            Organization Chart
                        </h5>
                    </div>
                    <div class="card-body p-4">
                        <div style="overflow-x:auto;">
                            <div class="d-flex flex-column align-items-center" style="min-width:300px;">

                                <!-- Manager -->
                                <t t-if="employee.parent_id">
                                    <div class="d-flex justify-content-center">
                                        <div class="org-node org-manager">
                                            <div class="org-avatar-wrap">
                                                <img t-if="employee.parent_id.image_1920"
                                                     t-attf-src="/web/image/hr.employee/{{employee.parent_id.id}}/image_1920/50x50"
                                                     class="rounded-circle"
                                                     style="width:48px;height:48px;object-fit:cover;"
                                                     alt="Manager"/>
                                                <div t-else=""
                                                     class="rounded-circle d-inline-flex align-items-center justify-content-center"
                                                     style="width:48px;height:48px;background:#6f42c1;color:#fff;font-size:18px;font-weight:700;">
                                                    <t t-esc="(employee.parent_id.name or 'M')[0]"/>
                                                </div>
                                            </div>
                                            <div class="org-details">
                                                <div class="org-name">
                                                    <t t-esc="employee.parent_id.name"/>
                                                </div>
                                                <div class="org-role">
                                                    <t t-esc="employee.parent_id.job_title or employee.parent_id.job_id.name or 'Manager'"/>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div style="width:2px;height:28px;background:#ced4da;margin:0 auto;"></div>
                                </t>

                                <!-- Current Employee -->
                                <div class="d-flex justify-content-center">
                                    <div class="org-node org-self">
                                        <div class="org-avatar-wrap">
                                            <img t-if="employee.image_1920"
                                                 t-attf-src="/web/image/hr.employee/{{employee.id}}/image_1920/50x50"
                                                 class="rounded-circle"
                                                 style="width:48px;height:48px;object-fit:cover;"
                                                 alt="You"/>
                                            <div t-else=""
                                                 class="rounded-circle d-inline-flex align-items-center justify-content-center"
                                                 style="width:48px;height:48px;background:#0d6efd;color:#fff;font-size:18px;font-weight:700;">
                                                <t t-esc="(employee.name or 'E')[0]"/>
                                            </div>
                                        </div>
                                        <div class="org-details">
                                            <div class="org-name" style="color:#0d6efd;">
                                                <t t-esc="employee.name"/>
                                            </div>
                                            <div class="org-role">
                                                <t t-esc="employee.job_title or employee.job_id.name or ''"/>
                                            </div>
                                            <span style="display:inline-block;background:#0d6efd;color:#fff;
                                                         border-radius:4px;font-size:10px;padding:1px 6px;margin-top:2px;">
                                                You
                                            </span>
                                        </div>
                                    </div>
                                </div>

                                <!-- Subordinates -->
                                <t t-if="employee.child_ids">
                                    <div style="width:2px;height:28px;background:#ced4da;margin:0 auto;"></div>
                                    <div class="d-flex flex-wrap justify-content-center" style="gap:16px;">
                                        <t t-foreach="employee.child_ids" t-as="child">
                                            <div class="d-flex flex-column align-items-center">
                                                <div style="width:2px;height:20px;background:#ced4da;"></div>
                                                <div class="org-node org-child">
                                                    <div class="org-avatar-wrap">
                                                        <img t-if="child.image_1920"
                                                             t-attf-src="/web/image/hr.employee/{{child.id}}/image_1920/50x50"
                                                             class="rounded-circle"
                                                             style="width:42px;height:42px;object-fit:cover;"
                                                             alt="Report"/>
                                                        <div t-else=""
                                                             class="rounded-circle d-inline-flex align-items-center justify-content-center"
                                                             style="width:42px;height:42px;background:#198754;color:#fff;font-size:16px;font-weight:700;">
                                                            <t t-esc="(child.name or 'S')[0]"/>
                                                        </div>
                                                    </div>
                                                    <div class="org-details">
                                                        <div class="org-name">
                                                            <t t-esc="child.name"/>
                                                        </div>
                                                        <div class="org-role">
                                                            <t t-esc="child.job_title or child.job_id.name or ''"/>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </t>
                                    </div>
                                </t>

                                <!-- No hierarchy -->
                                <t t-if="not employee.parent_id and not employee.child_ids">
                                    <p class="text-muted text-center mt-3">
                                        <i class="fa fa-info-circle me-1"></i>
                                        No organizational hierarchy configured.
                                    </p>
                                </t>

                            </div>
                        </div>
                    </div>
                </div>
            </t>
        </t>
    </template>

</odoo>