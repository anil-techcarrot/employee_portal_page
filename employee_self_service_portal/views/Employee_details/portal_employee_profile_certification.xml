<odoo>
    <template id="portal_employee_profile_certification">
        <t t-call="employee_self_service_portal.portal_employee_profile_base">
            <t t-set="section" t-value="'certification'"/>
            <t t-set="section_content">

                <!-- Success/Error Messages -->
                <div id="certMessageContainer" style="display: none;">
                    <div id="certSuccessMessage" class="alert alert-success alert-dismissible fade"
                         role="alert" style="display: none;">
                        <i class="fa fa-check-circle me-2"></i>
                        <span id="certSuccessText"></span>
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                    <div id="certErrorMessage" class="alert alert-danger alert-dismissible fade"
                         role="alert" style="display: none;">
                        <i class="fa fa-exclamation-triangle me-2"></i>
                        <span id="certErrorText"></span>
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                </div>

                <form id="certificationForm" action="/my/employee/certification" method="post"
                      enctype="multipart/form-data">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                    <!-- Certifications Text -->
                    <div class="card mb-4 shadow-sm">
                        <div class="card-header bg-light d-flex justify-content-between align-items-center">
                            <h5 class="mb-0">
                                <i class="fa fa-certificate text-primary me-2"></i>Certifications
                            </h5>
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <label class="form-label fw-bold">Certification Details</label>
                                <textarea name="x_certifications"
                                          id="certText"
                                          class="form-control"
                                          rows="5"
                                          readonly=""
                                          placeholder="List your certifications, licenses, and professional qualifications...">
                                    <t t-esc="employee.x_certifications"/>
                                </textarea>
                                <small class="text-muted">
                                    e.g., AWS Certified Solutions Architect, PMP, CPA...
                                </small>
                            </div>
                        </div>
                    </div>

                    <!-- Training Certificates Upload -->
                    <div class="card mb-4 shadow-sm">
                        <div class="card-header bg-light">
                            <h5 class="mb-0">
                                <i class="fa fa-folder-open text-primary me-2"></i>Supporting Documents
                            </h5>
                        </div>
                        <div class="card-body">
                            <div class="row g-3">

                                <!-- Training Certificates -->
                                <div class="col-md-6">
                                    <label class="form-label fw-bold">
                                        <i class="fa fa-certificate text-muted me-1"></i>Training Certificates
                                    </label>
                                    <t t-if="employee.training_certificates">
                                        <div class="mb-2">
                                            <a t-att-href="'/web/content/hr.employee/%s/training_certificates?download=true' % employee.id"
                                               class="btn btn-outline-success btn-sm"
                                               target="_blank">
                                                <i class="fa fa-download me-1"></i>
                                                <t t-esc="employee.training_certificates_filename or 'Download Certificate'"/>
                                            </a>
                                        </div>
                                    </t>
                                    <t t-else="">
                                        <p class="text-muted small mb-1">No file uploaded yet</p>
                                    </t>
                                    <input type="file"
                                           name="training_certificates"
                                           class="form-control form-control-sm"
                                           accept=".pdf,.jpg,.jpeg,.png"/>
                                    <small class="text-muted">PDF, JPG, PNG (Max: 5MB)</small>
                                </div>

                                <!-- Awards & Recognition contain -->
                                <div class="col-md-6">
                                    <label class="form-label fw-bold">
                                        <i class="fa fa-trophy text-muted me-1"></i>Awards &amp; Recognition
                                    </label>
                                    <t t-if="employee.awards_files">
                                        <div class="mb-2">
                                            <a t-att-href="'/web/content/hr.employee/%s/awards_files?download=true' % employee.id"
                                               class="btn btn-outline-success btn-sm"
                                               target="_blank">
                                                <i class="fa fa-download me-1"></i>
                                                <t t-esc="employee.awards_files_filename or 'Download Award'"/>
                                            </a>
                                        </div>
                                    </t>
                                    <t t-else="">
                                        <p class="text-muted small mb-1">No file uploaded yet</p>
                                    </t>
                                    <input type="file"
                                           name="awards_files"
                                           class="form-control form-control-sm"
                                           accept=".pdf,.jpg,.jpeg,.png"/>
                                    <small class="text-muted">PDF, JPG, PNG (Max: 5MB)</small>
                                </div>

                            </div>
                        </div>
                    </div>

                    <!-- Form Actions -->
                    <div class="card shadow-sm">
                        <div class="card-body text-center">
                            <div id="certFormActions" style="display: none;">
                                <button type="button" class="btn btn-secondary me-2"
                                        onclick="certCancelEdit()">
                                    <i class="fa fa-times me-1"></i>Cancel
                                </button>
                                <button type="submit" class="btn btn-primary">
                                    <i class="fa fa-check me-1"></i>Save Changes
                                </button>
                            </div>
                            <div id="certViewActions">
                                <p class="text-muted mb-3">
                                    Last updated:
                                    <strong>
                                        <t t-esc="employee.write_date.strftime('%d %b, %Y at %I:%M %p') if employee.write_date else 'Never'"/>
                                    </strong>
                                </p>
                                <button type="button" class="btn btn-outline-primary"
                                        onclick="certEnableEdit()">
                                    <i class="fa fa-edit me-1"></i>Edit Certifications
                                </button>
                            </div>
                        </div>
                    </div>
                </form>

                <script type="text/javascript">
                    <![CDATA[
let certOriginalData = {};

function certEnableEdit() {
    certStoreOriginal();
    const inputs = document.querySelectorAll('#certificationForm input, #certificationForm textarea');
    inputs.forEach(input => {
        if (input.type !== 'hidden') {
            input.removeAttribute('readonly');
            input.removeAttribute('disabled');
        }
    });
    document.getElementById('certFormActions').style.display = 'block';
    document.getElementById('certViewActions').style.display = 'none';
}

function certStoreOriginal() {
    const form = document.getElementById('certificationForm');
    const formData = new FormData(form);
    certOriginalData = {};
    for (let [key, value] of formData.entries()) {
        certOriginalData[key] = value;
    }
}

function certCancelEdit() {
    for (let [key, value] of Object.entries(certOriginalData)) {
        const input = document.querySelector(`[name="${key}"]`);
        if (input && input.type !== 'hidden' && input.type !== 'file') {
            input.value = value;
        }
    }
    certDisableEdit();
    certShowMessage('Changes cancelled.', 'info');
}

function certDisableEdit() {
    const inputs = document.querySelectorAll('#certificationForm input, #certificationForm textarea');
    inputs.forEach(input => {
        if (input.type !== 'hidden' && input.type !== 'file') {
            input.setAttribute('readonly', 'readonly');
        }
    });
    document.getElementById('certFormActions').style.display = 'none';
    document.getElementById('certViewActions').style.display = 'block';
}

// ✅ Form submit via AJAX
document.getElementById('certificationForm').addEventListener('submit', function (e) {
    e.preventDefault();
    const formData = new FormData(this);
    fetch('/my/employee/certification', {
        method: 'POST',
        body: formData
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            certShowMessage('Certifications updated successfully!', 'success');
            certDisableEdit();
        } else {
            certShowMessage('Error: ' + (data.error || 'Unknown error'), 'error');
        }
    })
    .catch(error => {
        console.error('Error:', error);
        certShowMessage('Network error. Please try again.', 'error');
    });
});

function certShowMessage(text, type) {
    const container = document.getElementById('certMessageContainer');
    const successMsg = document.getElementById('certSuccessMessage');
    const errorMsg = document.getElementById('certErrorMessage');
    successMsg.style.display = 'none';
    errorMsg.style.display = 'none';
    successMsg.classList.remove('show');
    errorMsg.classList.remove('show');
    if (type === 'success') {
        document.getElementById('certSuccessText').textContent = text;
        successMsg.style.display = 'block';
        successMsg.classList.add('show');
    } else {
        document.getElementById('certErrorText').textContent = text;
        errorMsg.style.display = 'block';
        errorMsg.classList.add('show');
    }
    container.style.display = 'block';
    container.scrollIntoView({behavior: 'smooth'});
    setTimeout(() => {
        successMsg.classList.remove('show');
        errorMsg.classList.remove('show');
    }, 5000);
}
                    ]]>
                </script>
            </t>
        </t>
    </template>
</odoo>